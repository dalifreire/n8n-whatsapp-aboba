        "query": "SELECT * FROM abo.cancelar_agendamento($1::bigint, $2::varchar, $3::text);",
        "options": {
          "queryReplacement": "={{ $json.appointment_id }},={{ $json.patient_phone }},={{ $json.reason }}"
