# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1500

# ============================================
# Supabase Database Configuration (PostgreSQL + pgvector for RAG)
# ============================================
SUPABASE_HOST=your_supabase_host_here
SUPABASE_PORT=your_supabase_port_here
SUPABASE_DATABASE=your_supabase_database_here
SUPABASE_USER=your_supabase_user_here
SUPABASE_PASSWORD=your_supabase_password_here
