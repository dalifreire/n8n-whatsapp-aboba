      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, titulo, conteudo, categoria, metadados, (1 - (embedding <=> $1::vector)) as similaridade \nFROM abo.documentos \nWHERE (1 - (embedding <=> $1::vector)) > 0.1 \nORDER BY embedding <=> $1::vector LIMIT 3;",
        "options": {
          "queryReplacement": "={{ '['+ $json.embedding + ']'}}]'"
        }
